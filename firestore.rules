rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ------------------ USERS ------------------ */
    match /users/{userId} {

      allow read;

      allow create: if request.auth != null;

      allow update, delete: if request.auth != null;
    }

    /* ------------------ NOVELS ------------------ */
    match /novels/{novelId} {
      // Anyone can read the novel document
      allow read: if true;

      // Only authenticated users can write (e.g., editing novel metadata)
      allow write: if request.auth != null;

      // -------------------- Chapters Subcollection --------------------
      match /chapters/{chapterId} {
        // Anyone can read chapters
        allow read: if true;

        // Only authenticated users can like or update chapters
        allow update: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    /* ------------------ POEMS ------------------ */
    match /poems/{poemId} {

      allow read: if true;

      allow create: if request.auth != null;
      
      allow update, delete: if request.auth != null;
    }
    
    /* ------------------ BANNERS ------------------ */
    match /banners/{bannerId} {
    
      allow read: if true;

      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }    
    
    /* ------------------ COMMENTS ------------------ */
    match /comments/{commentId} {

      allow read: if true;

      allow create: if request.auth != null;

      allow update, delete: if request.auth != null;
    }


    /* ------------------ POEM COMMENTS ------------------ */
    match /poemComments/{commentId} {

      allow read: if true;

      allow create: if request.auth != null;
      
      allow update, delete: if request.auth != null;
    }

    /* ------------------ ANNOUNCEMENTS ------------------ */
    match /announcements/{announcementId} {

      allow read: if true;

      allow create: if request.auth != null;

      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.authorId;
    }
    
    /* ------------------ DRAFTS ------------------ */
    match /drafts/{draftId} {
      
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }


    /* ------------------ NOTIFICATIONS ------------------ */
    match /notifications/{notificationId} {

      allow read: if request.auth != null
        && request.auth.uid == resource.data.toUserId;

      allow create: if request.auth != null;

      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.toUserId;
    }

   	/* ------------------ CONVERSATIONS ------------------ */
    match /conversations/{conversationId} {

      allow read, update, delete: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
    }

    /* ------------------ MESSAGES ------------------ */
    match /messages/{messageId} {

      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderId;

      // Only sender can edit or delete message
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.senderId;
    }
  }
}
